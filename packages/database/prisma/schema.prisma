// Tenant Manager — SSA Fight Wear
// Schema fonte da verdade. O e-commerce nunca escreve aqui: só lê via API pública.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// TENANT & ACESSO
// ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  roles        Role[]
  brands       Brand[]
  categories   Category[]
  collections  Collection[]
  suppliers    Supplier[]
  products     Product[]
  warehouses   Warehouse[]
  customers    Customer[]
  orders       Order[]
  coupons      Coupon[]
  campaigns    Campaign[]
  taxRules     TaxRule[]
  financialEntries FinancialEntry[]
  auditLogs    AuditLog[]

  @@map("tenants")
}

model Role {
  id        String   @id @default(uuid())
  tenantId  String
  name      String // OWNER_ADMIN, FINANCEIRO, ESTOQUE, ATENDIMENTO, MARKETING, AUDITOR, INTEGRACAO
  createdAt DateTime @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique // ex.: "products.create", "orders.refund", "finance.export"
  description String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id               String    @id @default(uuid())
  tenantId         String
  roleId           String
  name             String
  email            String
  passwordHash     String
  refreshTokenHash String?
  isActive         Boolean   @default(true)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role       @relation(fields: [roleId], references: [id])
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// TAXONOMIA / CATÁLOGO
// ─────────────────────────────────────────────────────────────

model Brand {
  id       String @id @default(uuid())
  tenantId String
  name     String
  slug     String

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
  @@map("brands")
}

model Category {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  slug     String
  parentId String?

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToSubcategory")
  products Product[]

  @@unique([tenantId, slug])
  @@map("categories")
}

model Collection {
  id       String @id @default(uuid())
  tenantId String
  name     String
  slug     String

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, slug])
  @@map("collections")
}

model Supplier {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  document String?
  email    String?
  phone    String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@map("suppliers")
}

model Product {
  id      String @id @default(uuid())
  tenantId String

  name             String
  description      String?
  richDescription  String?
  slug             String

  brandId      String?
  categoryId   String?
  collectionId String?
  supplierId   String?

  price       Decimal @db.Decimal(10, 2)
  promoPrice  Decimal? @db.Decimal(10, 2)
  promoStart  DateTime?
  promoEnd    DateTime?
  costPrice   Decimal? @db.Decimal(10, 2)

  weight String? // gramas
  height String? // cm
  width  String? // cm
  length String? // cm

  ncm   String?
  cest  String?
  cfop  String?
  origin String?

  metaTitle       String?
  metaDescription String?
  tags            String[]

  isActive     Boolean @default(true)
  isFeatured   Boolean @default(false)
  isNew        Boolean @default(false)
  isBestSeller Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand      Brand?      @relation(fields: [brandId], references: [id])
  category   Category?   @relation(fields: [categoryId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])

  variants ProductVariant[]
  images   ProductImage[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("products")
}

model ProductVariant {
  id        String @id @default(uuid())
  tenantId  String
  productId String

  sku     String
  barcode String?

  color    String?
  size     String?
  model    String?
  material String?

  price     Decimal? @db.Decimal(10, 2) // sobrescreve o preço do produto-pai quando definido
  costPrice Decimal? @db.Decimal(10, 2)
  weight    String?

  stock    Int @default(0)
  minStock Int @default(0)

  imageUrl String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  images          ProductImage[]
  stockMovements  StockMovement[]
  orderItems      OrderItem[]
  taxRules        TaxRule[]

  @@unique([tenantId, sku])
  @@index([tenantId, productId])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  variantId String?
  url       String
  altText   String?
  order     Int     @default(0)

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ─────────────────────────────────────────────────────────────
// ESTOQUE
// ─────────────────────────────────────────────────────────────

model Warehouse {
  id        String  @id @default(uuid())
  tenantId  String
  name      String
  isDefault Boolean @default(false)

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@map("warehouses")
}

enum StockMovementType {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  AJUSTE
  RESERVA
  LIBERACAO_RESERVA
}

model StockMovement {
  id          String            @id @default(uuid())
  tenantId    String
  variantId   String
  warehouseId String
  type        StockMovementType
  quantity    Int
  reason      String?
  referenceType String? // ex.: "ORDER", "INVOICE_IMPORT"
  referenceId   String?
  createdById String?
  createdAt   DateTime          @default(now())

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])

  @@index([tenantId, variantId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────
// CLIENTES
// ─────────────────────────────────────────────────────────────

model Customer {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  email     String
  document  String?
  phone     String?
  birthDate DateTime?
  isVip     Boolean   @default(false)
  createdAt DateTime  @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addresses Address[]
  orders    Order[]

  @@unique([tenantId, email])
  @@map("customers")
}

model Address {
  id         String  @id @default(uuid())
  customerId String
  label      String?
  street     String
  number     String?
  complement String?
  district   String?
  city       String
  state      String
  zipCode    String
  isDefault  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────────────────────────

enum OrderStatus {
  AGUARDANDO_PAGAMENTO
  PAGO
  EM_SEPARACAO
  ENVIADO
  ENTREGUE
  CANCELADO
  DEVOLVIDO
  REEMBOLSADO
}

model Order {
  id         String      @id @default(uuid())
  tenantId   String
  customerId String
  status     OrderStatus @default(AGUARDANDO_PAGAMENTO)

  subtotal Decimal @db.Decimal(10, 2)
  discount Decimal @default(0) @db.Decimal(10, 2)
  shipping Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  channel       String? // "storefront", "balcao", "whatsapp"
  notes         String?
  internalNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  items    OrderItem[]
  payments Payment[]
  shipments Shipment[]
  invoices Invoice[]
  coupons  Coupon[]
  financialEntries FinancialEntry[]

  @@index([tenantId, status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String
  gateway       String // "mercado_pago", "stripe"
  method        String? // "pix", "boleto", "credit_card"
  status        String
  amount        Decimal  @db.Decimal(10, 2)
  installments  Int      @default(1)
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Shipment {
  id            String    @id @default(uuid())
  orderId       String
  carrier       String? // "correios", "melhor_envio"
  trackingCode  String?
  shippingCost  Decimal?  @db.Decimal(10, 2)
  status        String    @default("PENDENTE")
  shippedAt     DateTime?
  deliveredAt   DateTime?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

// ─────────────────────────────────────────────────────────────
// MARKETING
// ─────────────────────────────────────────────────────────────

enum CouponType {
  PERCENTUAL
  VALOR_FIXO
  FRETE_GRATIS
}

model Coupon {
  id         String     @id @default(uuid())
  tenantId   String
  code       String
  type       CouponType
  value      Decimal    @db.Decimal(10, 2)
  startsAt   DateTime?
  endsAt     DateTime?
  usageLimit Int?
  usedCount  Int        @default(0)
  isActive   Boolean    @default(true)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  orders    Order[]

  @@unique([tenantId, code])
  @@map("coupons")
}

model Campaign {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  channel   String? // "email", "whatsapp", "instagram"
  startsAt  DateTime?
  endsAt    DateTime?
  couponId  String?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  coupon Coupon? @relation(fields: [couponId], references: [id])

  @@map("campaigns")
}

// ─────────────────────────────────────────────────────────────
// FISCAL & FINANCEIRO
// ─────────────────────────────────────────────────────────────

enum InvoiceType {
  NFE
  NFCE
}

model Invoice {
  id        String      @id @default(uuid())
  tenantId  String
  orderId   String
  type      InvoiceType
  status    String      @default("PENDENTE")
  accessKey String?
  series    String?
  number    String?
  issuedAt  DateTime?
  xmlUrl    String?
  pdfUrl    String?

  order Order @relation(fields: [orderId], references: [id])

  @@map("invoices")
}

model TaxRule {
  id        String  @id @default(uuid())
  tenantId  String
  variantId String?
  ncm       String
  uf        String
  regime    String // "SIMPLES_NACIONAL", "LUCRO_PRESUMIDO", "LUCRO_REAL"
  rate      Decimal @db.Decimal(6, 3)

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("tax_rules")
}

enum FinancialEntryType {
  RECEITA
  DESPESA
}

model FinancialEntry {
  id          String             @id @default(uuid())
  tenantId    String
  orderId     String?
  type        FinancialEntryType
  category    String
  description String?
  amount      Decimal            @db.Decimal(10, 2)
  dueDate     DateTime
  paidAt      DateTime?
  status      String             @default("PENDENTE")
  createdAt   DateTime           @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@map("financial_entries")
}

// ─────────────────────────────────────────────────────────────
// AUDITORIA
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String // ex.: "product.update", "order.refund"
  module    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, module])
  @@map("audit_logs")
}
